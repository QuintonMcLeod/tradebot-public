{
  "name": "stitch-ai-trading-dashboard",
  "version": "1.0.0",
  "description": "High-fidelity Electron dashboard for Tradebot SCI",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "concurrently \"npm run css:watch\" \"electron .\"",
    "css:build": "tailwindcss -i ./src/input.css -o ./dist/output.css",
    "css:watch": "tailwindcss -i ./src/input.css -o ./dist/output.css --watch"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "electron": "^28.0.0",
    "tailwindcss": "^3.4.1",
    "concurrently": "^8.2.2"
  }
}